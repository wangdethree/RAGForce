# ========== DeepSeek API ==========
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

# ========== PostgreSQL ==========
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ragforce
POSTGRES_PASSWORD=ragforce_secret
POSTGRES_DB=ragforce

# ========== Redis ==========
REDIS_URL=redis://localhost:6379/0

# ========== Milvus ==========
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=ragforce_documents

# ========== RabbitMQ ==========
RABBITMQ_URL=amqp://ragforce:ragforce_secret@localhost:5672/

# ========== MinIO ==========
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ragforce-documents

# ========== BGE Model Service ==========
EMBEDDING_SERVICE_URL=http://embedding:8001
RERANKER_SERVICE_URL=http://reranker:8002

# ========== File Storage ==========
UPLOAD_DIR=./uploads

# ========== Application ==========
APP_NAME=RAGForce
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production
